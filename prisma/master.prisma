generator client {
  provider = "prisma-client"
  output   = "../src/generated/master"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  dbPath          String
  taxNumber       String?
  email           String?
  phone           String?
  address         String?
  city            String?
  logoPath        String?
  logoLightPath   String?
  defaultCurrency String   @default("TRY")
  themeColor      String   @default("#059669")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
}

model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime
  currency  String
  rate      Float
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, currency])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  USER
}
